# =====================
# Runtime
# =====================
ENVIRONMENT=production
LOG_LEVEL=INFO
LOG_DIR=logs

# =====================
# MySQL / ODS database
# =====================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=ods
DB_CHARSET=utf8mb4
DB_CONNECT_TIMEOUT=10
DB_READ_TIMEOUT=600
DB_WRITE_TIMEOUT=600

# Source table
SOURCE_TABLE=ods_lx_product_performance
DATE_COLUMN=dt
# latest_date: use MAX(dt) in source table as window end; current_date: use today as window end
WINDOW_MODE=latest_date

# =====================
# Feishu Open Platform
# =====================
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_app_secret
FEISHU_APP_TOKEN=REclw3BsTiCMFcknZfIcdbySn1b

# Fill table_id if known. If left empty, the script will resolve by table name.
FEISHU_90D_TABLE_ID=
FEISHU_90D_TABLE_NAME=90天数据
FEISHU_7D_TABLE_ID=
FEISHU_7D_TABLE_NAME=7天数据

# 0 means no local pre-check. Set to 20000 if your bitable capacity is 20,000 rows.
MAX_FEISHU_RECORDS=0
